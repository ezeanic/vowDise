{
  "extends": ["stylelint-config-standard", "stylelint-config-tailwindcss"],
  "overrides": [
    {
      "files": ["**/*.{ts,tsx}"],
      "customSyntax": "postcss-styled-syntax"
    }
  ],
  "rules": {
    "declaration-block-no-duplicate-properties": true,
    "no-duplicate-selectors": true,
    "selector-class-pattern": null
  }
}
